# ── .dvcignore ──
# Fichiers exclus du tracking DVC

# Fichiers temporaires
*.tmp
*.log
*.pyc
__pycache__/

# Données brutes EDF (volumineuses, versionnées séparément dans le bucket)
data/eeg/*.edf

# Événements Spark
spark-logs/

# Notebooks (versionnés par Git uniquement)
*.ipynb_checkpoints/

# MLflow
mlruns/
